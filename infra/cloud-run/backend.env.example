# Reference for `gcloud run deploy stock-lens-api --set-env-vars ...`
# Not consumed automatically by any script.

PORT=8080
ALLOWED_ORIGINS=https://stock-lens-web-xxxxx.a.run.app
LLM_PROVIDER=mock

# Injected via --set-secrets, not plain env vars:
# SOLAR_API_KEY  -> Secret Manager secret "SOLAR_API_KEY" (unused placeholder, M3)
# GEMINI_API_KEY -> Secret Manager secret "GEMINI_API_KEY" (unused placeholder, M3)
# DART_API_KEY   -> Secret Manager secret "DART_API_KEY" (actually used today, M2 — see
#                    docs/deployment.md for the data/disclosures.json packaging gap)
