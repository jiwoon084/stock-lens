# Frontend
VITE_API_BASE_URL=http://localhost:8000

# Backend
ALLOWED_ORIGINS=http://localhost:5173

# LLM providers (do not commit real keys)
SOLAR_API_KEY=
GEMINI_API_KEY=
LLM_PROVIDER=mock

# Open DART (data/step1_corpcode.py, data/step2_disclosures.py — do not commit real key)
DART_API_KEY=

# data.go.kr — 금융위원회_주식시세정보 (real KRX daily prices, market_data_service.py M1).
# Get this from data.go.kr: sign up, open the "금융위원회_주식시세정보" API page, click
# "활용신청", wait for approval, then copy the "일반 인증키(Decoding)" value — NOT "Encoding".
# Empty/unset -> market_data_service.py falls back to mock prices.
KRX_API_KEY=

# GCP
GCP_PROJECT_ID=
GCP_REGION=asia-northeast3
GCP_ARTIFACT_REPOSITORY=stock-lens

# Cloud Run service names
FRONTEND_SERVICE_NAME=stock-lens-web
BACKEND_SERVICE_NAME=stock-lens-api
