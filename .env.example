# Frontend
VITE_API_BASE_URL=http://localhost:8000

# Backend
ALLOWED_ORIGINS=http://localhost:5173

# LLM providers (do not commit real keys) — user picks one per request (default solar),
# see frontend's LlmProviderToggle / MovementExplanationRequest.llm_provider. Either or both
# missing -> falls back to the deterministic rule-based analysis, never hard-fails.
SOLAR_API_KEY=
GEMINI_API_KEY=
# gemini-flash-latest is a Google-maintained alias that always points at their current free-tier
# Flash model — dated model names (gemini-2.5-flash, gemini-3.5-flash, ...) get individually
# deprecated/paid-gated over time (empirically: gemini-2.5-flash 404'd as "no longer available
# to new users" on a freshly created API key). If you see a 429 "prepayment credits are
# depleted" error instead, that's the *project* being on a paid Prepay plan — check
# https://ai.studio/projects billing, or create the key in a fresh project instead.
GEMINI_MODEL=gemini-flash-latest

# Default provider for POST /api/analysis/date (backend/app/services/llm/factory.py) — "solar"
# or "gemini". gemini_provider.py is interface-only for now (see its docstring), so leave this
# as "solar" until a real Gemini implementation is added. Unrelated to the llm_provider request
# field above, which is specific to the older /api/v1/explanations feature's user-selectable
# SOLAR/Gemini toggle.
LLM_PROVIDER=solar

# Open DART (data/step1_corpcode.py, data/step2_disclosures.py — do not commit real key)
DART_API_KEY=

# Naver News Search API (data/step5_news.py) — developers.naver.com에서 발급
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# data.go.kr — 금융위원회_주식시세정보 (real KRX daily prices, market_data_service.py M1).
# Get this from data.go.kr: sign up, open the "금융위원회_주식시세정보" API page, click
# "활용신청", wait for approval, then copy the "일반 인증키(Decoding)" value — NOT "Encoding".
# Empty/unset -> market_data_service.py falls back to mock prices.
KRX_API_KEY=

# KIS Developers (한국투자증권 Open API) 모의투자(demo) 계좌 — 장중 근실시간 현재가 조회
# (market_data_service.get_live_price(), GET /api/v1/stocks/{ticker}/live-price). apiportal.
# koreainvestment.com에서 모의투자용 APP KEY/SECRET을 발급받고, securities.koreainvestment.com
# 로그인 후 트레이딩 > 모의투자 > 주식/선물옵션 모의투자에서 계좌번호도 확인. 셋 중 하나라도
# 비어 있으면 실시간 배지 없이 기존 일봉 종가만 표시 — 절대 하드 실패하지 않음.
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=

# GCP
GCP_PROJECT_ID=
GCP_REGION=asia-northeast3
GCP_ARTIFACT_REPOSITORY=stock-lens

# Cloud Run service names
FRONTEND_SERVICE_NAME=stock-lens-web
BACKEND_SERVICE_NAME=stock-lens-api
