# Frontend
VITE_API_BASE_URL=http://localhost:8000

# Backend
ALLOWED_ORIGINS=http://localhost:5173

# LLM providers (do not commit real keys) — routed by difficulty, not fail-over:
# SOLAR-pro2 handles requests backed by more source evidence (harder to synthesize),
# Gemini Flash handles simple/few-source requests. Each is a same-request safety net for
# the other if it's missing a key or errors out.
# LLM_PROVIDER=mock forces the deterministic mock analysis (fast/free, used by tests).
# Any other value (e.g. "live") enables real routing, falling back to mock if both fail.
LLM_PROVIDER=mock
LLM_TIMEOUT=30
LLM_NUM_RETRIES=2

UPSTAGE_API_KEY=
SOLAR_MODEL=solar-pro2
SOLAR_BASE_URL=https://api.upstage.ai/v1/solar

# aistudio.google.com/apikey 에서 발급
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest

# Open DART (data/step1_corpcode.py, data/step2_disclosures.py — do not commit real key)
DART_API_KEY=

# Naver News Search API (data/step5_news.py) — developers.naver.com에서 발급
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# data.go.kr — 금융위원회_주식시세정보 (real KRX daily prices, market_data_service.py M1).
# Get this from data.go.kr: sign up, open the "금융위원회_주식시세정보" API page, click
# "활용신청", wait for approval, then copy the "일반 인증키(Decoding)" value — NOT "Encoding".
# Empty/unset -> market_data_service.py falls back to mock prices.
KRX_API_KEY=

# GCP
GCP_PROJECT_ID=
GCP_REGION=asia-northeast3
GCP_ARTIFACT_REPOSITORY=stock-lens

# Cloud Run service names
FRONTEND_SERVICE_NAME=stock-lens-web
BACKEND_SERVICE_NAME=stock-lens-api
